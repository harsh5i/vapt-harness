# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.venv/
venv/
.venv-vapt/
.vapt-bin/
.vapt-home/
.vapt-tools/

# Operator engagement state (regenerated per run)
vapt/harness/cache/
vapt/harness/source_cache/
vapt/harness/tests/snapshots/
vapt/harness/corpus/outcome_tuning.yaml
vapt/harness/corpus/outcome_tuning.md
vapt/harness/corpus/step_outcomes.jsonl
vapt/harness/corpus/step_outcomes.jsonl.lock

# Watch / queue runtime state (fixtures kept)
vapt/harness/watches/state/
vapt/harness/watches/ticks/
vapt/harness/watches/watch_daemon_heartbeat.jsonl

# OS noise
.DS_Store
Thumbs.db

# Regenerated by phaseN-check fixture commands
vapt/harness/tests/results/

# Records bucket: per-target engagement data (runs, evidence, pocs, reports,
# target profiles, adapters). Never enters the public mirror. Captive fixtures
# and the cross-engagement corpus now live with the engine under vapt/harness/.
vapt/engagements/*/
!vapt/engagements/.gitkeep

# Cloned target source for a run (target.yaml source_path); never committed.
engagement/

# Internal planning / strategy / build-history docs. Operator-facing truth
# lives in STATUS.md, README.md, CHEATSHEET.md, and vapt/ONBOARDING.md.
vapt/management/

# Knowledge base: case studies, lessons, vuln-class doctrine, program intel,
# novel-approaches registry. Stays local on the operator's machine. The
# harness reads this dir at runtime but does not require it to function;
# fresh clones start with an empty KB.
vapt/harness/knowledge/

# Outdated single-file harness export. Superseded by README + STATUS +
# CHEATSHEET + ONBOARDING.
vapt/harness/exports/

# Runtime queue state. The phaseN-check fixture seeds (the tracked
# YAMLs originally committed at decomposition time) ARE tracked because
# the check commands consume them. gitignore does not untrack files
# already in the index, so the seeds remain. The patterns below stop
# *new* runtime accumulation in the fixture dirs from polluting
# `git status` (phase4-check / harness-fixture writes new timestamped
# YAMLs on every run). Per-target queue subdirs (any name) are
# treated as engagement state and never tracked.
vapt/harness/queue/discovery/
vapt/harness/queue/*-fixture/*.yaml
vapt/harness/queue/*-fixture/*.yaml.lock
vapt/harness/queue/*-fixture/*.tmp
vapt/harness/queue/phase4_fixture/*.yaml
vapt/harness/queue/phase4_fixture/*.yaml.lock
vapt/harness/queue/phase4_fixture/*.tmp

# Cross-engagement candidate and submission ledgers. These hold
# operational data and must stay local-only.
vapt/harness/corpus/candidates.jsonl
vapt/harness/corpus/submissions.jsonl

# Runtime ledger lock files.
vapt/harness/corpus/*.jsonl.lock
