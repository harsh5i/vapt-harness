# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.venv/
venv/
.venv-vapt/
.vapt-bin/
.vapt-home/
.vapt-tools/

# Operator engagement state (regenerated per run)
vapt/harness/cache/
vapt/harness/source_cache/
vapt/harness/tests/snapshots/
vapt/harness/corpus/outcome_tuning.yaml
vapt/harness/corpus/outcome_tuning.md
vapt/harness/corpus/step_outcomes.jsonl
vapt/harness/corpus/step_outcomes.jsonl.lock

# Watch / queue runtime state (fixtures kept)
vapt/harness/watches/state/
vapt/harness/watches/ticks/
vapt/harness/watches/watch_daemon_heartbeat.jsonl

# OS noise
.DS_Store
Thumbs.db

# Regenerated by phaseN-check fixture commands
vapt/harness/tests/results/

# Records bucket: per-target engagement data (runs, evidence, pocs, reports,
# target profiles, adapters). Never enters the public mirror. Captive fixtures
# and the cross-engagement corpus now live with the engine under vapt/harness/.
vapt/engagements/*/
!vapt/engagements/.gitkeep

# Cloned target source for a run (target.yaml source_path); never committed.
engagement/

# Internal planning / strategy / build-history docs. Operator-facing truth
# lives in STATUS.md, README.md, CHEATSHEET.md, and vapt/ONBOARDING.md.
vapt/management/

# Outdated single-file harness export. Superseded by README + STATUS +
# CHEATSHEET + ONBOARDING.
vapt/harness/exports/

# Runtime queue state. The phaseN-check fixtures
# (advisory-refresh-fixture, harness-fixture, phase4_fixture,
# phase4_remote_check) ARE tracked because the check commands consume them.
vapt/harness/queue/discovery/
vapt/harness/queue/demo-pyml/

# Runtime ledger lock files.
vapt/harness/corpus/*.jsonl.lock
