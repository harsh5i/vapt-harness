# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.venv/
venv/
.venv-vapt/
.vapt-bin/
.vapt-home/
.vapt-tools/

# Operator engagement state (regenerated per run)
vapt/harness/runs/
vapt/harness/cache/
vapt/harness/source_cache/
vapt/harness/tests/snapshots/
vapt/harness/corpus/outcome_tuning.yaml
vapt/harness/corpus/outcome_tuning.md

# Watch / queue runtime state (fixtures kept)
vapt/harness/watches/state/
vapt/harness/watches/ticks/
vapt/harness/watches/watch_daemon_heartbeat.jsonl

# OS noise
.DS_Store
Thumbs.db

# Regenerated by phaseN-check fixture commands
vapt/harness/tests/results/

# Engagement workspace: operator/bounty-specific data, never pushed
# Holds bug_bounties/<target>/, harness_runs/, evidence, pocs, reports,
# scripts, env, runtime, templates from the original tree
engagement/

# Per-target bounty dirs must never enter the public mirror. Only the
# captive fixtures and the cross-engagement corpus schema travel with the repo.
vapt/bug_bounties/*/
!vapt/bug_bounties/_fixtures/
!vapt/bug_bounties/_shared/
